        self.assistant = SmartAssistant(self)
        self.overlay = SmartOverlay(self.editor) # Parent to editor so it floats over canvas
        
        self.assistant.suggestion_ready.connect(self.overlay.show_suggestion)
        self.overlay.action_clicked.connect(self.assistant.execute_action)
        
        # Position Overlay (Bottom Center)
        self.overlay.resize(300, 60)
        # self.overlay.move( ... ) # Dynamic positioning in resizeEvent
        
    def resizeEvent(self, event):
        if hasattr(self, 'overlay'):
            # Center at bottom of editor
            geo = self.editor.geometry()
            x = geo.center().x() - self.overlay.width() // 2
            y = geo.bottom() - 80 
            self.overlay.move(x, y)
        super().resizeEvent(event)
