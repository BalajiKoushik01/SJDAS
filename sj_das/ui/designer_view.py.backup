    def import_photo_weave(self):
        """Imports a photo and runs Photo-Weave Dithering."""
        path, _ = QFileDialog.getOpenFileName(self, "Select Photo", "", "Images (*.png *.jpg *.jpeg)")
        if path:
            try:
                from sj_das.core.photo_weave import PhotoWeaveEngine
                engine = PhotoWeaveEngine()
                
                # 480 Hooks, 16 Colors (Maximum for complex photo)
                res = engine.process_photo_for_loom(path, 480, 16)
                
                # Convert RGB-Numpy to BGR-CV2
                res_bgr = cv2.cvtColor(res, cv2.COLOR_RGB2BGR)
                
                self.editor.set_image(res_bgr)
                QMessageBox.information(self, "Photo Weave", "Photo Dithered & Map Ready!")
            except ImportError as e:
                QMessageBox.critical(self, "Missing Dependency", f"Photo Engine requires PIL: {e}")
            except Exception as e:
                QMessageBox.critical(self, "Error", str(e))

    def import_image_ai(self):
        """Professional loom import with specifications dialog."""
        # Show loom import dialog
        dialog = LoomImportDialog(parent=self)
        
        if dialog.exec() != QDialog.DialogCode.Accepted:
            return
        
        specs = dialog.get_specifications()
        
        if not specs["image_path"]:
            QMessageBox.warning(self, "No File", "Please select an image file")
            return
        
        try:
            from sj_das.core.image_ingestor import ImageIngestionEngine
            ingestor = ImageIngestionEngine()
            
            # Show Wait Cursor
            QApplication.setOverrideCursor(Qt.CursorShape.WaitCursor)
            
            # Run AI Ingestion with loom specifications
            processed_cv = ingestor.process_image(
                specs["image_path"],
                target_width=specs["hooks"],
                max_colors=specs["colors"]
            )
            
            # Load result into editor
            self.editor.set_image(processed_cv)
            
            # Store specifications for export
            self.current_loom_specs = {
                "hooks": specs["hooks"],
                "reed": specs["reed"],
                "component": specs["component"]
            }
            
            QApplication.restoreOverrideCursor()
            
            QMessageBox.information(
                self, 
                "Loom Ready", 
                f"Design Loaded:\n"
                f"• Hooks: {specs['hooks']}\n"
                f"• Reed: {specs['reed']}\n"
                f"• Component: {specs['component']}\n"
                f"• Colors: {specs['colors']}"
            )
            
        except ImportError as e:
            QApplication.restoreOverrideCursor()
            QMessageBox.critical(self, "Missing Dependency", f"AI Engine requires libraries: {e}")
        except Exception as e:
            QApplication.restoreOverrideCursor()
            QMessageBox.critical(self, "Import Error", str(e))

    def show_generation_dialog(self):
        # Quick Dialog for Prototype
        from PyQt6.QtWidgets import QInputDialog
        text, ok = QInputDialog.getText(self, "AI Loom Generator", "Describe Pattern (e.g. 'Peacock Design'):")
        if ok and text:
            # Run Generation (Using our new Engine)
            from sj_das.core.generative_engine import GenerativeDesignEngine
            engine = GenerativeDesignEngine()
            
            # Use current loom width if set, else 480
            w = 480 
            h = 120 # Standard border height
            
            try:
                img = engine.generate_border(text, w, h)
                # Load result into editor? Or just show it?
                # Let's ask user: "Add to Current Layer?"
                self.editor.set_image(self._qimage_to_cv2(img)) # For now replace base
                QMessageBox.information(self, "Success", "Generated Loom-Ready Pattern!")
            except Exception as e:
                QMessageBox.critical(self, "Error", str(e))

    def _qimage_to_cv2(self, qimg):
        # Helper to convert back
        qimg = qimg.convertToFormat(QImage.Format.Format_RGB888)
        w, h = qimg.width(), qimg.height()
        ptr = qimg.bits()
        ptr.setsize(h * w * 3)
        arr = np.array(ptr).reshape(h, w, 3)
        return arr[..., ::-1].copy() # RGB->BGR
        
    def create_toolbar(self):
        """Creates a Photoshop-style vertical toolbar using QFrame and custom buttons directly."""
        # Container to hold toolbar and force width
        self.toolbar_container = QFrame()
        self.toolbar_container.setFixedWidth(50)
        self.toolbar_container.setObjectName("toolbar") # For QSS
        
        layout = QVBoxLayout(self.toolbar_container)
        layout.setContentsMargins(5, 10, 5, 10)
        layout.setSpacing(8)
        layout.setAlignment(Qt.AlignmentFlag.AlignTop)
        
        self.tool_group = QButtonGroup(self)
        self.tool_group.setExclusive(True)
        
        # Helper to create styled tool inputs
        def add_tool_btn(tool_id, icon_name, tooltip, shortcut, is_checked=False):
            btn = QPushButton()
            btn.setFixedSize(40, 40)
            btn.setCheckable(True)
            btn.setToolTip(f"{tooltip} ({shortcut})")
            btn.setShortcut(shortcut)
            btn.setIcon(DASIcons.get_icon(icon_name))
            btn.setIconSize(QSize(24, 24))
            btn.setProperty("class", "tool-btn") # For QSS
            
            btn.clicked.connect(lambda: self.set_tool(tool_id))
            
            self.tool_group.addButton(btn)
            layout.addWidget(btn)
            if is_checked: btn.setChecked(True)
            return btn

        # Tools
        self.btn_move = add_tool_btn(PixelEditorWidget.TOOL_PAN, "pan", "Pan / Move", "H")
        self.btn_select = add_tool_btn(PixelEditorWidget.TOOL_SELECT_RECT, "select", "Rectangular Marquee", "M")
        self.btn_lasso = add_tool_btn(PixelEditorWidget.TOOL_LASSO, "lasso", "Lasso Tool", "L")
        self.btn_wand = add_tool_btn(PixelEditorWidget.TOOL_MAGIC_WAND, "wand", "Magic Wand", "W")
        
        # Separator as a dummy widget or frame
        line = QFrame(); line.setFrameShape(QFrame.Shape.HLine); line.setFixedWidth(30); line.setStyleSheet("background-color: #444; max-height: 1px;")
        layout.addWidget(line)
        layout.setAlignment(line, Qt.AlignmentFlag.AlignHCenter)
        
        self.btn_brush = add_tool_btn(PixelEditorWidget.TOOL_BRUSH, "brush", "Brush Tool", "B", True)
        self.btn_eraser = add_tool_btn(PixelEditorWidget.TOOL_ERASER, "eraser", "Eraser Tool", "E")
        self.btn_fill = add_tool_btn(PixelEditorWidget.TOOL_FILL, "fill", "Paint Bucket", "G")
        
        layout.addSpacing(5)
        
        self.btn_picker = add_tool_btn(PixelEditorWidget.TOOL_PICKER, "picker", "Eyedropper", "I")
        self.btn_shape = add_tool_btn(PixelEditorWidget.TOOL_RECT, "rect", "Rectangle Shape", "U")
        self.btn_line = add_tool_btn(PixelEditorWidget.TOOL_LINE, "line", "Line Tool", "")
        self.btn_crop = add_tool_btn(PixelEditorWidget.TOOL_PERSPECTIVE, "crop", "Perspective Crop (4-Point)", "C")

